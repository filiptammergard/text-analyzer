{
	"name": "text-analyzer",
	"version": "3.0.0",
	"description": "Analyze text: count characters, words, sentences, paragraphs, and reading time",
	"keywords": [
		"text-analyzer",
		"text",
		"text-analysis",
		"characters",
		"words",
		"word-count",
		"reading-time"
	],
	"homepage": "https://github.com/filiptammergard/text-analyzer#readme",
	"bugs": {
		"url": "https://github.com/filiptammergard/text-analyzer/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/filiptammergard/text-analyzer.git"
	},
	"license": "MIT",
	"author": {
		"name": "Filip Tammergård",
		"email": "filip+npm@tammergard.se",
		"url": "https://tammergard.se"
	},
	"sideEffects": false,
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/index.d.mts",
			"default": "./dist/index.mjs"
		}
	},
	"main": "dist/index.mjs",
	"types": "dist/index.d.mts",
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsdown src/index.ts --format esm --dts",
		"format": "prettier --write .",
		"format-check": "prettier --check .",
		"lint": "eslint .",
		"prepublishOnly": "pnpm build",
		"release": "pnpm changeset publish",
		"review": "pnpm install --frozen-lockfile && pnpm format-check && pnpm lint && pnpm typecheck && pnpm test && pnpm build",
		"test": "vitest --run",
		"typecheck": "tsc"
	},
	"devDependencies": {
		"@changesets/cli": "^2.31.0",
		"@tammergard/eslint-config-base": "^6.1.0",
		"@tammergard/prettier-config": "^3.0.0",
		"@tammergard/tsconfig": "^3.0.0",
		"eslint": "^10.4.0",
		"prettier": "^3.8.3",
		"tsdown": "^0.22.0",
		"typescript": "^6.0.3",
		"vitest": "^4.1.7"
	},
	"packageManager": "pnpm@10.33.2",
	"engines": {
		"node": ">=24"
	},
	"publishConfig": {
		"access": "public",
		"provenance": true
	}
}
